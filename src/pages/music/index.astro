---
import Layout from "../../layouts/Layout.astro";
import ContactSection from "../../components/ContactSection.astro";
import PageHeader from "../../components/PageHeader.astro";
import Link from "../../components/Link.astro";

const releases = [
	{
		title: "SIGNAL DECAY",
		year: "2024",
		type: "EP",
		notes: "Generative percussion, feedback loops, tape saturation.",
	},
	{
		title: "FAULT LINES",
		year: "2023",
		type: "LP",
		notes: "Composed over six months. Coincided with a period of extended on-call shifts. You can probably tell.",
	},
	{
		title: "THRESHOLD",
		year: "2023",
		type: "Single",
		notes: "18 minutes of textural ambience, originally made for a short film score.",
	},
	{
		title: "DEAD CHANNELS",
		year: "2022",
		type: "EP",
		notes: "Industrial club tracks. The loudest thing I've made so far.",
	},
];
---

<Layout title="Music — Portfolio">
	<div class="max-w-7xl mx-auto px-6 py-16">
		<div>
			<PageHeader
				title="MUSIC"
				link={{ href: "https://linktr.ee/grid.district", label: "linktr.ee/grid.district" }}
			/>

			<!-- Bio -->
			<div class="grid md:grid-cols-2 gap-16 mb-20">
				<div class="space-y-5 text-muted-foreground" style="font-size: 0.95rem; line-height: 1.8;">
					<p>
						I've been making electronic music longer than I've been writing software, though I've only
						recently started putting things out. It took a while to feel like anything was worth releasing —
						now I'm making up for lost time.
					</p>
					<p>
						The music sits somewhere between ambient and industrial. I work entirely in Ableton Live, which
						imposes a certain discipline: you can't blame the gear.
					</p>
					<p>
						Alongside production, I've been learning to DJ — playing mostly at the events I help organise
						through a local producers' club I'm part of. We run sessions where people bring
						works-in-progress, tear each other's mixes apart in the best way, and occasionally put on actual
						shows. I've also collaborated with a few DJs on production work — some of that is reflected
						<Link href="/projects">in my projects</Link>.
					</p>
				</div>

				<!-- Tools -->
				<div>
					<p
						class="text-muted-foreground uppercase border-b border-border pb-3 mb-6"
						style="font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em;"
					>
						TOOLS
					</p>
					<div
						class="flex items-center gap-3 text-foreground"
						style="font-family: 'DM Mono', monospace; font-size: 0.8rem;"
					>
						<span style="color: var(--primary);">—</span>
						Ableton Live 12
					</div>
					<p class="text-muted-foreground mt-4" style="font-size: 0.8rem; line-height: 1.7;">
						That's the whole setup. Constraints are useful.
					</p>
				</div>
			</div>

			<!-- Releases -->
			<div>
				<div class="border-b border-border pb-3 mb-0">
					<p
						class="text-muted-foreground uppercase"
						style="font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em;"
					>
						RELEASES
					</p>
				</div>

				<div class="divide-y divide-border">
					{
						releases.map((r, i) => (
							<div
								class="py-7 flex flex-col md:flex-row md:items-start gap-4"
								style={`animation: fade-in 0.4s ease-out both; animation-delay: ${i * 0.07}s;`}
							>
								<span
									class="text-muted-foreground shrink-0 w-8"
									style="font-family: 'DM Mono', monospace; font-size: 0.65rem;"
								>
									0{i + 1}
								</span>
								<div class="flex-1">
									<div class="flex items-baseline flex-wrap gap-3 mb-2">
										<h3
											class="text-foreground uppercase"
											style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.4rem; letter-spacing: 0.04em;"
										>
											{r.title}
										</h3>
										<span
											class="text-muted-foreground"
											style="font-family: 'DM Mono', monospace; font-size: 0.65rem;"
										>
											{r.year}
										</span>
										<span
											class="border border-border text-muted-foreground px-2 py-0.5"
											style="font-family: 'DM Mono', monospace; font-size: 0.6rem;"
										>
											{r.type}
										</span>
									</div>
									<p class="text-muted-foreground" style="font-size: 0.875rem; line-height: 1.6;">
										{r.notes}
									</p>
								</div>
							</div>
						))
					}
				</div>
			</div>

			<div class="mt-16 border-t border-border pt-6">
				<p class="text-muted-foreground" style="font-family: 'DM Mono', monospace; font-size: 0.7rem;">
					ALIAS NOT LISTED HERE — ASK DIRECTLY OR FIND IT VIA THE LINK ABOVE.
				</p>
			</div>

			<ContactSection />
		</div>
	</div>
</Layout>
