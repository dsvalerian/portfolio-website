---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Dmitri Salov" } = Astro.props;
const pathname = Astro.url.pathname;

const isWorkActive = pathname.startsWith("/projects");
const isMusicActive = pathname.startsWith("/music");
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<nav
			class="fixed top-0 left-0 right-0 z-50 border-b border-border"
			style="background-color: rgba(9,9,9,0.95); backdrop-filter: blur(8px);"
		>
			<div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
				<a
					href="/"
					class="text-foreground hover:text-primary transition-colors mono-ui"
					style="font-size: 0.8rem; letter-spacing: 0.08em;"
				>
					[ DMITRI_SALOV ]
				</a>

				<div class="flex items-center gap-8">
					<a
						href="/projects"
						class={`transition-colors tracking-widest uppercase mono-ui ${isWorkActive ? "text-primary" : "text-muted-foreground hover:text-foreground"}`}
						style="font-size: 0.7rem;"
					>
						WORK
					</a>
					<a
						href="/music"
						class={`transition-colors tracking-widest uppercase mono-ui ${isMusicActive ? "text-primary" : "text-muted-foreground hover:text-foreground"}`}
						style="font-size: 0.7rem;"
					>
						MUSIC
					</a>
					<a
						id="contact-nav-btn"
						href="/#contact"
						class="border border-primary text-primary px-3 py-1 hover:bg-primary hover:text-primary-foreground transition-colors mono-ui"
						style="font-size: 0.7rem; letter-spacing: 0.1em;"
					>
						CONTACT
					</a>
				</div>
			</div>
		</nav>

		<main class="pt-14">
			<slot />
		</main>

		<footer class="border-t border-border mt-32">
			<div class="max-w-7xl mx-auto px-6 py-8 flex items-center justify-between">
				<span class="text-muted-foreground mono-ui" style="font-size: 0.7rem;"> © COPYRIGHT 2026 </span>
				<a
					href="/privacy"
					class="text-muted-foreground hover:text-foreground transition-colors mono-ui"
					style="font-size: 0.7rem;"
				>
					PRIVACY POLICY
				</a>
			</div>
		</footer>

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				if (window.location.hash === "#contact") {
					setTimeout(() => {
						document.getElementById("contact")?.scrollIntoView({ behavior: "smooth" });
					}, 80);
				}

				document.getElementById("contact-nav-btn")?.addEventListener("click", e => {
					e.preventDefault();
					if (window.location.pathname === "/") {
						document.getElementById("contact")?.scrollIntoView({ behavior: "smooth" });
					} else {
						window.location.href = "/#contact";
					}
				});
			});
		</script>
	</body>
</html>
